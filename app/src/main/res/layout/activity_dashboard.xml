<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".activities.Dashboard"
    android:background="@color/bg_deep">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingHorizontal="27dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end">

            <Button
                android:id="@+id/btnDeslogar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deslogar"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="8dp"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>


        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/ctvEvoCarteira"
            android:layout_width="match_parent"
            android:layout_height="300dp" />

        <!-- Linha 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtAtivoNome1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nome Provisório"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/txtAtivoPreco1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preco Provisório"
                android:textColor="@color/text_primary"/>

        </LinearLayout>

        <!-- Linha 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtAtivoNome2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nome Provisório"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/txtAtivoPreco2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preco Provisório"
                android:textColor="@color/text_primary"/>

        </LinearLayout>

        <!-- Linha 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtAtivoNome3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nome Provisório"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/txtAtivoPreco3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preco Provisório"
                android:textColor="@color/text_primary"/>

        </LinearLayout>

        <!-- Linha 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtAtivoNome4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nome Provisório"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/txtAtivoPreco4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preco Provisório"
                android:textColor="@color/text_primary"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnAportes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Aportes"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_alignParentBottom="true"
            android:background="@color/bg_deep"
            app:menu="@menu/bottom_menu"

            app:itemActiveIndicatorStyle="@null"
            app:labelVisibilityMode="unlabeled"
            app:itemIconTint="@color/buttom_nav_colors"
            android:layout_gravity="bottom"/>
    </LinearLayout>

</ScrollView>