<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingVertical="10dp">

    <!-- Ícone do ativo -->
    <TextView
        android:id="@+id/txtIconAtivo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_icon_circle"
        android:gravity="center"
        android:text="B"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />
    
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNomeAtivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bitcoin"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"/>
        
        <TextView
            android:id="@+id/txtSubtituloAtivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qualquer coisa"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

    </LinearLayout>
    
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">
        
        <TextView
            android:id="@+id/txtValorAtivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R$ 99999"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtVariacaoAtivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="▲ +18,4%"
            android:textColor="@color/green_positive"
            android:textSize="12sp"
            android:textStyle="bold"/>

    </LinearLayout>
</LinearLayout>